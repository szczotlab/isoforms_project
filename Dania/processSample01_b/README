inR2="fastqWithUmiTrimmed/P28203_5007_S7_R2_001.extractedUmi.trimmed.fastq.gz"
outR1="fastqWithUmiTrimmedFixed/P28203_5007_S7_R1_001.extractedUmi.trimmed.fixedNames.fastq.gz"
outR2="fastqWithUmiTrimmedFixed/P28203_5007_S7_R2_001.extractedUmi.trimmed.fixedNames.fastq.gz"

$python fixFastqReadNames.py --inFastq1 $inR1 --inFastq2 $inR2 --outFastq1 $outR1 --outFastq2 $outR2 --threads 10


### 5: map reads with STAR

# check on active jobs
sacct --user=dama4465
squeue -u dama4465

# needed files and tools
module load rnastar/2.7.11b

genomeDir=/cfs/klemming/home/d/dama4465/Projects/M_Szczot_2405/naiss2024-22-1277/Dania/Db/mouse/gencode/release_M37/refSTAR/refSTAR-2.7.11b-primaryRef-fullAnnotation-overhang133/ref

fileR1=fastqWithUmiTrimmedFixed/P28203_5007_S7_R1_001.extractedUmi.trimmed.fixedNames.fastq.gz
fileR2=fastqWithUmiTrimmedFixed/P28203_5007_S7_R2_001.extractedUmi.trimmed.fixedNames.fastq.gz

mkdir mapped
outPrefix=mapped/P28203_5007_S7_

# map, keeping unmapped reads in the bam file
STAR --runThreadN 30 --runMode alignReads --genomeDir $genomeDir --readFilesIn $fileR1 $fileR2 --outFilterType BySJout --outFilterMultimapNmax 20 --alignSJoverhangMin 8 --alignSJDBoverhangMin 1 --outFilterMismatchNmax 999 --outFilterMismatchNoverReadLmax 0.04 --alignIntronMin 20 --alignIntronMax 1000000 --alignMatesGapMax 1000000 --outFileNamePrefix $outPrefix --outSAMtype BAM SortedByCoordinate --outSAMattributes NH HI AS nM XS --outSAMunmapped Within --readFilesCommand zcat

# index bam file

module purge & module load samtools/1.20
samtools index mapped/P28203_5007_S7_Aligned.sortedByCoord.out.bam



### 6: add UMI and cell barcode as tags (extract from the read name)

module load samtools/1.20

samtools view -h mapped/P28203_5007_S7_Aligned.sortedByCoord.out.bam | \
awk '
BEGIN {OFS="\t"}
# Keep header lines as-is
/^@/ {print; next}
{
    cb=""; ub="";
    # Extract CB and UB from read name
    if ($1 ~  /_OX:[A-Z]+_CR:[A-Z-]+$/) {
        match($1, /_OX:([A-Z]+)_CR:([A-Z-]+)$/, arr)
        ub=arr[1]; cb=arr[2] 
        $0 = $0 "\tCR:Z:" cb "\tOX:Z:" ub
    }
    else if ($1 ~ /_CR:[A-Z-]+$/) {
        match($1, /_CR:([A-Z-]+)$/, arr)
        cb=arr[1]
        $0 = $0 "\tCR:Z:" cb
    }
    print
}' | samtools view -b -o mapped/P28203_5007_S7_Aligned.sortedByCoord.out.withTags.bam


