mkdir fastqWithUmiTrimmedFixed

python=/cfs/klemming/home/d/dama4465/Projects/M_Szczot_2405/naiss2024-22-1277/Dania/Apps/pixiEnvs/python/python-v3.11.14/.pixi/envs/default/bin/python

