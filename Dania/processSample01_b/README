#### 1: extract UMIs

# reserve node and ssh into the reserved node (with ~50GB of RAM)
salloc --nodes=1 -t 20:00:00 -A naiss2025-22-1458 -p main --mem=50000MB
echo $SLURM_NODELIST # nid001077
ssh nid001077

cd /cfs/klemming/home/d/dama4465/Projects/M_Szczot_2405/naiss2024-22-1277/Dania/Projects/M_Szczot_2405/examineFastqFiles/processSample01_b


mkdir fastqWithUmi

R1in="Raw/P28203_5007_S7_R1_001.fastq.gz"
R2in="Raw/P28203_5007_S7_R2_001.fastq.gz"

outR1withUmi="fastqWithUmi/P28203_5007_S7_R1_001.umi.fastq.gz"
outR2withUmi="fastqWithUmi/P28203_5007_S7_R2_001.umi.fastq.gz"
log="fastqWithUmi/umi_extract.log"
outR1withoutUmi="fastqWithUmi/P28203_5007_S7_R1_001.withoutUmi.fastq.gz"
outR2withoutUmi="fastqWithUmi/P28203_5007_S7_R2_001.withoutUmi.fastq.gz"

umi_tools=/cfs/klemming/home/d/dama4465/Projects/M_Szczot_2405/naiss2024-22-1277/Dania/Apps/pixiEnvs/umi_tools/umi_tools-1.1.6/.pixi/envs/default/bin/umi_tools 

$umi_tools extract --extract-method=regex --stdin=$R1in --read2-in=$R2in --stdout=$outR1withUmi --read2-out=$outR2withUmi --bc-pattern='^(?P<discard_1>ATTGCGCAATG{s<=1})(?P<umi_1>.{8}).*' --log=$log --filtered-out=$outR1withoutUmi --filtered-out2=$outR2withoutUmi

### 2: concatenate fastqs

cat $outR1withUmi $outR1withoutUmi > fastqWithUmi/P28203_5007_S7_R1_001.extractedUmi.fastq.gz
cat $outR2withUmi $outR2withoutUmi > fastqWithUmi/P28203_5007_S7_R2_001.extractedUmi.fastq.gz

### 3: trim adapter(s)

# reserve node and ssh into the reserved node (with ~50GB of RAM)
salloc --nodes=1 -t 20:00:00 -A naiss2025-22-1458 -p main --mem=50000MB
echo $SLURM_NODELIST # nid002592
ssh nid002592

cd /cfs/klemming/home/d/dama4465/Projects/M_Szczot_2405/naiss2024-22-1277/Dania/Projects/M_Szczot_2405/examineFastqFiles/processSample01_b


module load cutadapt/5.1

inR1="fastqWithUmi/P28203_5007_S7_R1_001.extractedUmi.fastq.gz"
inR2="fastqWithUmi/P28203_5007_S7_R2_001.extractedUmi.fastq.gz"
outR1="fastqWithUmiTrimmed/P28203_5007_S7_R1_001.extractedUmi.trimmed.fastq.gz"
outR2="fastqWithUmiTrimmed/P28203_5007_S7_R2_001.extractedUmi.trimmed.fastq.gz"
report="fastqWithUmiTrimmed/cutadapt.report.txt"

cutadapt -a CTGTCTCTTATACACATCT -A N{8}CATTGCGCAATCTGTCTCTTATACACATCT -A CTGTCTCTTATACACATCT --minimum-length 10 --pair-filter=any -o $outR1 -p $outR2 $inR1 $inR2 > $report


